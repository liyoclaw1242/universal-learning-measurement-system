{
  "name": "@ulms/shell",
  "version": "0.1.0",
  "private": true,
  "description": "ULMS formal v1 — desktop shell for teachers to run the multi-agent pipeline",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit && tsc -p electron/tsconfig.json --noEmit",
    "test": "vitest",
    "e2e": "electron-vite build && playwright test",
    "e2e:headed": "electron-vite build && playwright test --headed",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"electron/**/*.ts\""
  },
  "dependencies": {
    "@ulms/ui": "*",
    "js-yaml": "^4.1.0",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.8.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@playwright/test": "^1.48.2",
    "@vitejs/plugin-react": "^4.3.3",
    "electron": "^33.0.0",
    "electron-vite": "^2.3.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  }
}
