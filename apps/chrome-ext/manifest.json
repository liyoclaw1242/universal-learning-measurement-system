{
  "manifest_version": 3,
  "name": "ULMS Learn",
  "description": "Send YouTube videos, articles, and multi-page books to ULMS as learning material.",
  "version": "0.2.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Send to ULMS"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": [
    "http://127.0.0.1:9527/*",
    "https://www.youtube.com/*",
    "https://i.ytimg.com/*",
    "<all_urls>"
  ]
}
