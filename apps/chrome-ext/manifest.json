{
  "manifest_version": 3,
  "name": "ULMS Learn",
  "description": "Send YouTube videos, articles, and tweets to ULMS as learning material.",
  "version": "0.1.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Send to ULMS"
  },
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "http://127.0.0.1:9527/*",
    "https://www.youtube.com/*",
    "https://i.ytimg.com/*",
    "https://www.google.com/*"
  ]
}
